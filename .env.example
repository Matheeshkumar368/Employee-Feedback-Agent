# =============================================================================
# AuraHR — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB — Required
# Atlas (production): mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/aurahr?retryWrites=true&w=majority
# Local Docker:       mongodb://aurahr:aurahr_dev_pass@localhost:27017/aurahr?authSource=admin
# Local (no auth):    mongodb://localhost:27017/aurahr
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aurahr?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# JWT — Required
# Generate a strong random secret (minimum 32 characters):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_a_strong_random_secret_minimum_32_chars


# -----------------------------------------------------------------------------
# Google Gemini AI — Required for AI features
# Get your free API key at: https://makersuite.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# NextAuth (used for NEXTAUTH_URL routing — no NextAuth library required)
# Set to your production URL when deploying (no trailing slash)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=replace_with_a_strong_random_secret_minimum_32_chars
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Node environment — set to "production" in all deployed environments
# -----------------------------------------------------------------------------
NODE_ENV=development
