# =============================================================================
# AuraHR — .gitignore
# =============================================================================

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Next.js ───────────────────────────────────────────────────────────────────
/.next/
/out/
/build/

# ── Environment — NEVER commit secrets ───────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep the example template
!.env.example

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
